# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/job-tracker?retryWrites=true&w=majority

# JWT secret — use a long random string
JWT_SECRET=change-this-to-a-long-random-secret

# Resend API key (for stale job emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Your verified sender domain on Resend
RESEND_FROM=Job Tracker <notifications@yourdomain.com>

# Your deployed Vercel URL (used in email links)
APP_URL=https://your-app.vercel.app

# Protects the cron endpoint — set same value in Vercel env vars
CRON_SECRET=some-random-secret-string
